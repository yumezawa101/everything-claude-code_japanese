# .env.example -- 必要な環境変数の一覧
# このファイルを .env にコピーして、実際の値を入力してください。
# .env を絶対にバージョン管理にコミットしないでください。
#
# 使い方:
#   cp .env.example .env
#   # .env を編集して実際の値を入力

# ─── Anthropic ────────────────────────────────────────────────────────────────
# Anthropic API キー (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# ─── GitHub ───────────────────────────────────────────────────────────────────
# GitHub パーソナルアクセストークン（MCP GitHub サーバー用）
GITHUB_TOKEN=

# ─── オプション: Docker プラットフォームの上書き ──────────────────────────────
# DOCKER_PLATFORM=linux/arm64  # Intel Mac / CI の場合は linux/amd64

# ─── オプション: パッケージマネージャの上書き ──────────────────────────────────
# CLAUDE_CODE_PACKAGE_MANAGER=npm  # npm | pnpm | yarn | bun

# ─── セッションとセキュリティ ─────────────────────────────────────────────────
# GitHub ユーザー名（CI スクリプトの認証コンテキストで使用）
GITHUB_USER="your-github-username"

# CI の差分チェックに使用するメイン開発ブランチ
DEFAULT_BASE_BRANCH="main"

# session-start.sh のパス（test/test_session_start.sh で使用）
SESSION_SCRIPT="./session-start.sh"

# 生成された MCP 設定ファイルのパス
CONFIG_FILE="./mcp-config.json"

# ─── オプション: 詳細ログ ──────────────────────────────────────────────────────
# セッションおよび CI スクリプトの詳細ログを有効化
ENABLE_VERBOSE_LOGGING="false"
